/* Oh-Shit Network Security Dashboard — Textual CSS */

Screen {
    layout: vertical;
}

#main-body {
    layout: horizontal;
    height: 1fr;
}

#left-panel {
    width: 32;
    min-width: 24;
    border-right: solid $primary;
    layout: vertical;
    overflow-y: hidden;
}

#summary-btn {
    width: 100%;
    height: 3;
    margin: 0;
}

#host-panel {
    width: 100%;
    height: 1fr;
    overflow-y: scroll;
}

#host-panel-title {
    background: $primary;
    color: $text;
    width: 100%;
    text-align: center;
    padding: 0 1;
}

/* Right panel must fill its vertical space */
#right-panel {
    width: 1fr;
    height: 100%;
}

/* Summary panel — hidden by default, shown when summary-btn toggled */
#summary-panel {
    display: none;
    width: 1fr;
    height: 1fr;
    overflow-y: auto;
    padding: 1;
}

NetworkSummaryPanel Static {
    width: 100%;
}

/* TabbedContent AND ContentSwitcher both default to height:auto — override both */
#detail-tabs {
    height: 1fr;
}

ContentSwitcher {
    height: 1fr;
}

/* TabPane fills ContentSwitcher */
TabPane {
    height: 100%;
    padding: 0;
}

/* Inner widgets fill their TabPane */
HostDetailTab {
    height: 100%;
    overflow-y: scroll;
}

FindingsTable {
    height: 100%;
}

FindingsTable > DataTable {
    height: 100%;
}

RemediationPanel {
    height: 100%;
}

RemediationPanel > VerticalScroll {
    height: 100%;
}

#bottom-panel {
    height: 12;
    border-top: solid $primary;
    layout: vertical;
}

#scan-progress {
    height: 3;
    padding: 0 1;
}

#log-feed {
    height: 9;
    padding: 0 1;
}

HostListItem {
    height: 1;
    padding: 0;
}

HostListItem > Horizontal {
    height: 1;
}

.host-name {
    width: 1fr;
    padding: 0 1;
    overflow: hidden;
}

.host-state {
    width: auto;
    color: $text-muted;
    text-style: dim;
}

/* Risk badge colours */
.badge-critical { background: $error; color: $text; }
.badge-high     { background: $warning; color: $text-muted; }
.badge-medium   { background: $warning-lighten-2; color: $text-muted; }
.badge-low      { background: $success; color: $text; }
.badge-info     { background: $accent; color: $text; }

/* EOL badge on host list items */
.eol-badge {
    width: auto;
    padding: 0 1;
}
.eol-badge-critical { background: $error; color: $text; text-style: bold; }
.eol-badge-high     { background: $warning; color: $text; text-style: bold; }
.eol-badge-medium   { background: $warning-lighten-2; color: $text-muted; }

/* Host detail panel */
#detail-header {
    background: $surface;
    padding: 0 1;
    width: 100%;
    margin-bottom: 1;
}

#detail-os, #detail-kernel, #detail-mac, #detail-ssh, #detail-seen, #detail-vendor, #detail-iot, #detail-esphome {
    padding: 0 1;
}

#detail-eol {
    padding: 0 1;
    margin-bottom: 0;
}

#detail-seen {
    color: $text-muted;
    text-style: dim;
}

#ports-label {
    padding: 1 1 0 1;
    text-style: bold;
}

#ports-table {
    height: 1fr;
}

/* Remediation panel */
.remed-title {
    text-style: bold;
    padding: 1 1 0 1;
}

.remed-desc {
    color: $text-muted;
    padding: 0 2;
}

.remed-step {
    color: $success;
    padding: 0 2;
}

.remed-note {
    color: $text-muted;
    padding: 0 2;
}

.remed-blank {
    height: 1;
}

.remed-evidence {
    color: $text-muted;
    text-style: italic dim;
    padding: 0 2;
}

.remed-sep {
    color: $surface-lighten-2;
    padding: 0 1;
}

/* Progress bar area */
#step-label {
    color: $text-muted;
    text-style: dim;
}
